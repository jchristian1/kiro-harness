# kiro-worker environment configuration
# Copy this file to .env and adjust values for your environment

# Database
DATABASE_URL=sqlite:///./kiro_worker.db

# Workspace safety
# All workspace paths must be under this root
WORKSPACE_SAFE_ROOT=/tmp/kiro-worker/workspaces

# Kiro CLI
# Install kiro-cli: curl -fsSL https://cli.kiro.dev/install | bash
KIRO_CLI_PATH=kiro-cli
KIRO_DEFAULT_AGENT=repo-engineer
KIRO_CLI_TIMEOUT=300

# Logging
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=4000
